After running, `src/astaroth/DSL/local/mhdsolver.ac` has
```
else if(AC_enum_iforcing_cont__mod__forcing[i_88_109-1] == enum_tg_string)   {
          fact_87_88_109=2.*AC_ampl_ff__mod__forcing[i_88_109-1]
          ac_transformed_pencil_fcont[i_88_109-1].x=+fact_87_88_109*AC_sinx__mod__forcing[vertexIdx.x][i_88_109]*AC_cosy__mod__forcing[AC_m__mod__cdata-1][i_88_109-1]*AC_cosz__mod__forcing[AC_n__mod__cdata-1][i_88_109-1]
          ac_transformed_pencil_fcont[i_88_109-1].y=-fact_87_88_109*AC_cosx__mod__forcing[vertexIdx.x][i_88_109]*AC_siny__mod__forcing[AC_m__mod__cdata-1][i_88_109-1]*AC_cosz__mod__forcing[AC_n__mod__cdata-1][i_88_109-1]
          ac_transformed_pencil_fcont[i_88_109-1].z=0.
