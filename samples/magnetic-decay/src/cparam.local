!  -*-f90-*-  (for Emacs)    vim:set filetype=fortran:  (for vim)
!
!  cparam.local
!
!  Local settings concerning grid size and number of CPUs.
!  This file is included by cparam.f90
!
!integer, parameter :: ncpus=8,nprocx=2,nprocy=2,nprocz=ncpus/(nprocx*nprocy)
integer, parameter :: ncpus=1,nprocx=1,nprocy=1, nprocz=1
!integer, parameter :: nxgrid=512,nygrid=512,nzgrid=512
integer, parameter :: nxgrid=32,nygrid=32,nzgrid=32

