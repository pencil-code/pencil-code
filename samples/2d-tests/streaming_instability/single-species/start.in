!                              -*-f90-*-     (for emacs)
!
!  Initialization parameters for linear streaming instability.
!
&init_pars
    xyz0 = -0.02617993877991494, -0.02617993877991494, -0.02617993877991494
    Lxyz = 0.05235987755982988, 0.05235987755982988, 0.05235987755982988
    lwrite_ic = .true., lwrite_aux = .true.
/
&eos_init_pars
    gamma = 1.0
    rho0 = 1.0
    cs0 = 6.283185307179586
/
&hydro_init_pars
    Omega = 6.283185307179586
/
&density_init_pars
    ldensity_nolog = .true.
    beta_glnrho_global = -0.1, 0.0, 0.0
/
&shear_init_pars
    qshear = 1.5
/
&particles_init_pars
    lcalc_uup = .true.
    particle_mesh = 'tsc'
    initxxp = 'streaming_coldstart'
    amplxxp = 1e-6
    coeff = (0.0462916,-0.2743072), (0.2739304,0.0039293), (0.0083263,0.2768866), (-0.0174121,-0.2770347), (0.2767976,-0.0187568), (0.017413,0.2770423), (-6.7e-06,-6.91e-05)
    kx_xxp = 120.0, kz_xxp = 120.0
    tausp = 0.015915494309189534
    eps_dtog = 0.2
    lmigration_redo = .true.
/
&particles_drag_init_pars
    gx_gas = 3.947841760435743
    lset_drag_equilibrium = .true., ldrag_equilibrium_global = .true.
    ldrag_on_gas = .true., ldrag_on_par = .true.
    taus = 0.1
/
