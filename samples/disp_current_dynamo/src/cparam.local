!                       -*-f90-*-    (for Emacs)
!  cparam.local
!
!  Local settings concerning grid size and number of CPUs.
!  This file is included by cparam.f90
!
!  1 chunk for divE_as_aux
!
! MAUX CONTRIBUTION 1
! COMMUNICATED AUXILIARIES 0
!
integer, parameter :: ncpus=4,nprocx=1,nprocz=2,nprocy=ncpus/(nprocx*nprocz)
integer, parameter :: nxgrid=16,nygrid=nxgrid,nzgrid=nxgrid
