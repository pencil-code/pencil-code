!  -*-f90-*-  (for Emacs)    vim:set filetype=fortran:  (for vim)
!
!  sample file for 1-D sound wave
!
&run_pars
  cvsid="$Id: run.in,v 1.3 2026/03/09 03:20:58 brandenb Exp $"
  nt=10000, it1=500, isave=50000, itorder=3
  dsnap=2e5, dvid=1e5, dtmin=-1e-12
  lwrite_aux=T, lpencil_check=F
  lpencil_check_small=F
  dt=100.
/
&power_spectrum_run_pars
  lcorrect_integer_kcalc=T
/
&special_run_pars
  lbackreact_infl=T, ldt_backreact_infl=T
  echarge_type='erun'
  Gamma_phi0=1e-8, aphimax=45., lrho_rad_apply=T, lrho_rad_apply2=T
  !rhophim_crit=1e-29
/
