!
!  Run parameters for the particles-breakup sample
!
&run_pars
  cvsid='$Id$',
  nt=10000, it1=500, cdt=0.05, cdtv=0.05, isave=1000, itorder=3
  dsnap=1.0e37, dvid=1.0e37, dtmin=1e-12, dtmax=0.05
  lpencil_check=F
  lpencil_check_small=F
  dt=5e-4
/
&eos_run_pars
/
&density_run_pars
/
&hydro_run_pars
/
&particles_run_pars
  ldragforce_gas_par=F
  ldragforce_dust_par = T
  ldraglaw_stokesschiller = T
  lnostore_uu = F
  gravz_profile='const'
  gravz=-981.0
/
&viscosity_run_pars
  nu=0.15
/
&particles_radius_run_pars
/
&particles_number_run_pars
/
&particles_breakup_run_pars
  lparticles_breakup_rt=T
  rt_we_min=350.0                ! RT used when We_g >= rt_we_min
  lparticles_breakup_kh=F
  kh_we_min=100.0                ! KH used when We_g >= kh_we_min and RT inactive
  lparticles_breakup_pe=T        ! PE catches the rest (bag, multimode, ...)
  pe_we_crit=12.0
  pe_child_factor=0.5
  pe_min_diameter=1.0e-12
  pe_floor_diameter=1.0e-12
  pe_max_shrink_ratio=0.001
  lprint_breakup_mode=T          ! print one line at every breakup event
  tstart_particles_breakup=0.0
  kh_B0=0.61	
  kh_B1=40.0
  kh_B2=0.05
  rt_CRT=0.1
  rt_Ctau=1.0
  rt_method=1
  sigma_liq=72.0
  kh_min_child_npswarm=1e-6
/
