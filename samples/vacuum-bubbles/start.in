!  -*-f90-*-  (for Emacs)    vim:set filetype=fortran:  (for vim)
!
! Initialisation parameters
!
&init_pars
  cvsid='$Id: start.in,v 1.3 2024/05/11 11:52:38 brandenb Exp $'
  unit_system='set'
  lperi=T, T, T
  !lperi=F, T, T
  !bcx='a2','a2'
  xyz0=-10., -10., -10.
  xyz1=+10., +10., +10.
  lwrite_aux=T
  lread_aux=T
/
&special_init_pars
  initspecial='bubble'
  lambda_phi=.5
  delta_phi =-1.6305
  lphi_normalized_units=T
/
