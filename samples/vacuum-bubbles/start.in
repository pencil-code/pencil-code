!  -*-f90-*-  (for Emacs)    vim:set filetype=fortran:  (for vim)
!
! Initialisation parameters
!
&init_pars
  cvsid='$Id: start.in,v 1.3 2024/05/11 11:52:38 brandenb Exp $'
  unit_system='set'
  lperi=T, T, T
  xyz0=-100., -100., -100.
  xyz1=+100., +100., +100.
  lwrite_aux=T
  lread_aux=T
/
&klein_gordon_init_pars
  initspecial='nothing'
  lambda_phi=.5
  delta_phi =-1.6305
  lphi_normalized_units=T
  bubble_size_factor=1.7
/
&gravitational_waves_hTXk_init_pars
/
