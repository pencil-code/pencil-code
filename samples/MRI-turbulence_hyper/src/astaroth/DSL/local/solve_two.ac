#include "mhdsolver.ac"
#
fixed_boundary Kernel twopass_solve_final(int step_num){
  write( F_UU,  rk_final(F_UU, step_num) )
  write( F_RHO, rk_final(F_RHO,step_num) )
  write( F_AA,  rk_final(F_AA, step_num) )
  for dustspec in 0:AC_ndustspec__mod__cparam
  {
  	write(F_DUST_VELOCITY[dustspec], rk_final(F_DUST_VELOCITY[dustspec],step_num))
  	write(F_DUST_DENSITY[dustspec], rk_final(F_DUST_DENSITY[dustspec],step_num))
  }
}
