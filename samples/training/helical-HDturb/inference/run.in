!  -*-f90-*-  (for Emacs)    vim:set filetype=fortran:  (for vim)
!
!  run parameters for forced helical MHD turbulence
!
&run_pars
  cvsid='$Id$',
  nt=500, it1=10, cdt=0.2, cdtv=0.3, isave=10000, itorder=3 !(longer run)
  dsnap=5, dvid=1e10,  !(for longer run)
  d2davg=1e10           !(for sample run)
  !dspec=.1, lspec_start=T, ou_spec=T, ab_spec=T, vel_spec=T, lr_spec=T !(for energy spectra)
  ! uu_spec
  dspec=1e10, ou_spec=T, ab_spec=T, vel_spec=T, lr_spec=T !(for energy spectra)
  random_gen='system'
  random_gen='min_std'
  random_gen='nr_f90'  !(Use machine-indep numerical receipes random numbers)
  lpencil_check=F      !(checks for redundany of pencils)
 !comment_char='%'     !(useful when using matlab for visualization)
  lequatorz=T          !(to indicate that north/south diagnostics in in z)
/
&eos_run_pars
/
&hydro_run_pars
  lconservative=T
  lconservative_pressure_on_rhs=T
/
&density_run_pars
  lupw_lnrho=T
  ldensity_nolog=T
/
&forcing_run_pars
!try reducing (0.01)
  iforce='helical', force=0.01, relhel=1.
/
&viscosity_run_pars
  mu=5e-3
  ivisc='rho-nu-const'
  lrate_of_strain_as_aux=T
/
&power_spectrum_run_pars
  lzero_spec_zerok=T
/
&gpu_run_pars
  ltest_bcs=F
  lcuda_aware_mpi=F
/
