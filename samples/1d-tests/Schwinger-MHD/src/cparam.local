!  -*-f90-*-  (for Emacs)    vim:set filetype=fortran:  (for vim)
!
!  cparam.local
!
!  Local settings concerning grid size and number of CPUs.
!  This file is included by cparam.f90
!
! MVAR CONTRIBUTION 0
! MAUX CONTRIBUTION 2
!
integer, parameter :: ncpus=4,nprocx=4,nprocz=1,nprocy=ncpus/(nprocx*nprocz)
integer, parameter :: nxgrid=64,nygrid=1,nzgrid=1
!integer, parameter :: nxgrid=64,nygrid=nxgrid,nzgrid=nxgrid
!integer, parameter :: nxgrid=64,nygrid=nxgrid,nzgrid=1
!integer, parameter :: nxgrid=32,nygrid=nxgrid,nzgrid=nxgrid
