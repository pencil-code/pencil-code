!  -*-f90-*-  (for Emacs)    vim:set filetype=fortran:  (for vim)
!
!  sample file for 1-D sound wave
!
&run_pars
  cvsid="$Id: run.in,v 1.1 2026/04/14 14:40:21 brandenb Exp $"
  nt=7000, it1=100, isave=2000, itorder=3
  dsnap=1e5, dvid=1e5, tmax=2e9, dtmin=-1e-12
  dspec=1e5, lspec_start=F, ou_spec=T, ab_spec=T, ele_spec=T, sp_spec=T, mu_spec=T, Lor_spec=T, OmU_spec=T, ro_spec=T, gph_spec=T
  lwrite_aux=T, lpencil_check=F
  lpencil_check_small=F
  lspec_tcrit=T, tspec_crit_log_interval=1e6, lwrite_last_powersnap=F
  lsnap_tcrit=T, tsnap_crit_log_interval=1e6
  lvid_tcrit=T, tvid_crit_log_interval=1e6
/
&eos_run_pars
/
&hydro_run_pars
/
&density_run_pars
  lrelativistic_eos=T
  idiff='normal', diffrho=1e5
/
&viscosity_run_pars
  nu=1e5
/
&magnetic_run_pars
  ldensity_add_je_heating=F
  llorentzforce=F
/
&power_spectrum_run_pars
  lcorrect_integer_kcalc=T
/
&backreact_infl_run_pars
  lbackreact_infl=T, ldt_backreact_infl=T, Ndiv=0, cdt_phi=1e-2, lold_ldt_phi=T !(should change to lold_ldt_phi=F, and could relax cdt_phi=.1)
  echarge_type='erun'
  lrho_chi_inhom=T, wstate_tolerance=1e-10  !(should omit wstate_tolerance, which changes the result)
  Gamma_phi0=1e-7, lrho_rad_apply2=F
  lheating_keep_on=T, lwstate_crit=T, Gamma_phi_exp=-5.  !(should Gamma_phi_exp, but then it crashes with the current resolution or nu values)
  !solve_phi_criterion='rhophi', a4rhophim_crit=1e-30   !(should be uncommented, but this changes currently the results)
  !lold_lrho_chi_dtconstraint=F  !(should be uncommented, but this changes currently the results)
  lrho_chi=T
  !lswitch_toMHD_when_heating=F, lswitch_toMHD_when_nophi=F  !(should be uncommented, but this changes currently the results)
  !lswitch_toMHD_at_lna=T, lna_switch_toMHD=4.17  !(should be uncommented, but this changes currently the results)
  !lsmooth_Gamma_phi=T, dlnascale_reheating=1., lg_Gamma_phi_fraction_firststep=-8.  !(should be uncommented, but this changes currently the results)
/
&disp_current_run_pars
  luse_scale_factor_in_sigma=T
  lcollinear_EB=T, sigB_prefactor=1., sigE_prefactor=1.
  lallow_bprime_zero=T
  lphi_hom=F, lphi_linear_regime=F
  ldensity_add_je_heating=T, lohmic_heating_ee=T, lohmic_heating_justee=T
  lapply_Gamma_corr=F
  alpf=90.
  llorentzforce_ee=T
  cdt_sigE=1.
  lresistive_gauge_ee=T
  !llate_reset_el_pencil=T
  linclude_dphiB_in_MHD=T, linclude_gphixE_in_MHD=T
  lcorrect_sign_adphiB_term=T, lignore_adphiB_term_in_MHD_current=F
/
